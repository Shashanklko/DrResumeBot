# pyenv
#   For a library or binary, you should probably not check in .python-version
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case you'd like to ignore it, uncomment the following line:
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   poetry.lock
#   pyproject.toml is NOT ignored!

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#pdm.lock
#   pdm-python is created by `pdm use` and should be ignored
.pdm-python
#   .pdm-build/ is created by `pdm build` and should be ignored
.pdm-build/

# PEP 582; used by e.g. github.com/pypa/pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

